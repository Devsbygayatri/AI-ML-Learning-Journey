   "source": [
    "# Relational plots\n",
    "# scatter plot\n",
    "sns.get_dataset_names()\n",
    "tips = sns.load_dataset(\"tips\")\n",
    "print(tips.head())\n",
    "\n",
    "sns.scatterplot(\n",
    "    data=tips,\n",
    "    x=\"total_bill\",\n",
    "    y=\"tip\",\n",
    "    hue=\"time\"\n",
    ")\n",
    "plt.show()\n",
    "\n",
    "# line plot\n",
    "flights = sns.load_dataset(\"flights\")  # loaded flight data\n",
    "\n",
    "sns.lineplot(\n",
    "    data=flights,\n",
    "    x=\"year\",\n",
    "    y=\"passengers\" #with year our passengers have increased\n",
    ")\n",
    "plt.show()\n",
    "\n",
    "#Confidence interval(ci) -> 95% default ----> shaded region in 2nd graph ( mean + - ci)"
   ]
  },
