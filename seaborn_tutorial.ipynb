   "source": [
    "# Relational plots - Scatter plot / Line plot \n",
    "sns.set_theme(style = \"ticks\")\n",
    "\n",
    "sns.relplot(         # here bestfit is scatterplot\n",
    "    data = tips,\n",
    "    x = \"total_bill\", # x is independent\n",
    "    y = \"tip\",        # y is dependent on x \n",
    "    col =\"time\",     # gives in column wise wrt time\n",
    "    hue = \"smoker\",  #differentiating with colors b/w smokers and non-smokers\n",
    "    size = \"size\",\n",
    "    style = \"smoker\" # gives different linestyle for smokers and non-smokers\n",
    ")"
   ]
  },
