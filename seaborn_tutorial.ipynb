   "source": [
    "#Categorical Plots  -> Bar plots / Box plots\n",
    "\n",
    "# Bar plots\n",
    "sns.barplot(\n",
    "    data = tips,\n",
    "    x = \"day\",         # how much tips given based on total bill on each day by both male and female seperately\n",
    "    y = \"total_bill\",\n",
    "    hue = \"sex\"\n",
    ")\n",
    "plt.show() # writing this will seperately give u output for both plots, otherwise everything gets mixed up in one\n",
    "\n",
    "# Box plots\n",
    "sns.boxplot(         #shows outliers who paid a lot of extra-tips day-wise\n",
    "    data = tips,\n",
    "    x = \"day\",         \n",
    "    y = \"total_bill\"\n",
    ")\n",
    "plt.show()"
   ]
